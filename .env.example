# Bub Agent Configuration Example
# 复制这个文件为 .env 并填入你的配置

# ============================================
# 基础配置
# ============================================

# AI 模型名称
# 支持的格式:
#   - openrouter:qwen/qwen3-coder-next
#   - gemini-3.1-flash-lite-preview
#   - claude-opus-4-6
BUB_MODEL=openrouter:qwen/qwen3-coder-next

# API 认证密钥
BUB_API_KEY=your-api-key-here

# API 端点 URL
BUB_API_BASE=https://your-api-endpoint.com/v1

# API 格式 (completion, responses, messages)
BUB_API_FORMAT=completion

# ============================================
# 高级配置
# ============================================

# 最大步骤数 (默认: 50)
BUB_MAX_STEPS=50

# 最大 token 数 (默认: 1024)
BUB_MAX_TOKENS=1024

# 模型超时时间(秒，可选)
# BUB_MODEL_TIMEOUT_SECONDS=300

# 备用模型(可选)
# BUB_FALLBACK_MODEL=openrouter:qwen/qwen3-coder-next

# Bub 主目录(可选，默认 ~/.bub)
# BUB_HOME=/path/to/custom/home

# ============================================
# 多 Provider 配置 (高级用法)
# ============================================
# 如果你需要为不同的 provider 配置不同的 API key 和 base URL，
# 可以使用以下格式:

# OpenRouter
# BUB_OPENROUTER_API_KEY=your-openrouter-key
# BUB_OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Gemini
# BUB_GEMINI_API_KEY=your-gemini-key
# BUB_GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1

# Claude
# BUB_CLAUDE_API_KEY=your-claude-key
# BUB_CLAUDE_API_BASE=https://api.anthropic.com/v1

# 注意: 多 provider 配置时，模型名称需要包含 provider 前缀
# 例如: BUB_MODEL=openrouter:qwen/qwen3-coder-next
